# Server
PORT=3001
NODE_ENV=development

# E-mail notificaties (optioneel – zonder SMTP worden aanvragen alleen opgeslagen)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Serre Exclusief <noreply@serreexclusief.nl>"
NOTIFY_EMAIL=info@serreexclusief.nl

# Admin endpoint (GET /api/quotes)
ADMIN_KEY=change-me-in-production